STORE_CORS=*
ADMIN_CORS=*
AUTH_CORS=*
JWT_SECRET=replace_with_secure_value
COOKIE_SECRET=replace_with_secure_value

# Cloud backend URL for this Medusa instance.
MEDUSA_BASE_URL=https://your-medusa-cloud-url

# Admin API token used by TCA sync route when calling admin endpoints.
MEDUSA_ADMIN_API_TOKEN=replace_with_admin_api_token

# Publishable key expected from TCA app sync requests.
MEDUSA_PUBLISHABLE_KEY=pk_xxx
